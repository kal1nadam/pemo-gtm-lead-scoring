# ============================================
# Pemo GTM Lead Scoring - Environment Template
# Copy to .env and fill in your values
# DO NOT commit .env to git
# ============================================

# --- HubSpot ---
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# --- Trello ---
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_HOT_ID=
TRELLO_BOARD_WARM_ID=
TRELLO_BOARD_COLD_ID=

# --- Slack (Bot Token approach) ---
SLACK_BOT_TOKEN=
SLACK_CHANNEL_HOT=#leads-hot
SLACK_CHANNEL_ALERTS=#leads-alerts
SLACK_CHANNEL_DIGEST=#leads-digest

# --- Calendly ---
CALENDLY_LINK=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- n8n ---
N8N_INSTANCE_URL=

# --- Exa (optional) ---
EXA_API_KEY=
ENRICHMENT_MODE=mock
